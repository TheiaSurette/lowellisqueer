# Google Calendar API
# 1. Create a Google Cloud project at https://console.cloud.google.com
# 2. Enable the Google Calendar API
# 3. Create an API key (restrict to Calendar API + your domain)
# 4. Make your Google Calendar public (Settings → Access permissions)
# 5. Copy the Calendar ID from Settings → Integrate calendar
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
NEXT_PUBLIC_GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Featured events — Google Calendar colorId (1-11) that marks featured events
# See https://developers.google.com/calendar/api/v3/reference/colors/get
# 11 = Tomato (red), 9 = Grape (purple), 5 = Banana (yellow), etc.
GOOGLE_CALENDAR_FEATURED_COLOR_ID=11

# Google Form for event submissions
NEXT_PUBLIC_EVENT_FORM_URL=https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
